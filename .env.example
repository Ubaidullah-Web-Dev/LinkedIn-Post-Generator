# ── LinkedIn Post Automator v2 — Environment Variables ──
# Copy this file to .env and fill in your secrets.
# .env takes precedence over config.json for all API keys.

# AI Providers (at least one required)
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# LinkedIn Session Cookies
LINKEDIN_LI_AT=
LINKEDIN_JSESSIONID=
